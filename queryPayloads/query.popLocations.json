                ],
                "neq": "id",
                "nin": [
                    "id1",
                    "id2"
                ]
            },
            "popLocationCloudInterconnectFilterInput": {
                "taggingMethod": {
                    "eq": "DOT1Q",
                    "in": "DOT1Q",
                    "neq": "DOT1Q",
                    "nin": "DOT1Q"
                }
            },
            "stringFilterInput": {
                "eq": "string",
